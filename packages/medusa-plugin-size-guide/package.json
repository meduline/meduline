{
  "name": "@meduline/medusa-plugin-size-guide",
  "version": "0.1.1",
  "description": "Reusable size guides for Medusa v2 with product and product-type assignment plus store/admin APIs.",
  "author": "Meduline",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meduline/meduline.git"
  },
  "bugs": {
    "url": "https://github.com/meduline/meduline/issues"
  },
  "homepage": "https://github.com/meduline/meduline#readme",
  "files": [
    ".medusa/server",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "medusa-v2",
    "medusa-plugin",
    "size-guide",
    "sizing-chart",
    "ecommerce"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.13.4",
    "@medusajs/cli": "2.13.4",
    "@medusajs/framework": "2.13.4",
    "@medusajs/icons": "2.13.4",
    "@medusajs/medusa": "2.13.4",
    "@medusajs/test-utils": "2.13.4",
    "@medusajs/ui": "4.1.4",
    "@swc/core": "^1.7.28",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.13.4",
    "@medusajs/cli": "^2.13.4",
    "@medusajs/framework": "^2.13.4",
    "@medusajs/icons": "^2.13.4",
    "@medusajs/medusa": "^2.13.4",
    "@medusajs/test-utils": "^2.13.4",
    "@medusajs/ui": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
